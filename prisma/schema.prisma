// ============================================================================
// SCHEMA PRISMA - ERP INMOBILIARIO
// Versión: 0.7
// Fecha: 2026-02-24
// ============================================================================
//
// HISTORIAL DE DECISIONES ACUMULADAS:
//
// [v0.1] Schema inicial basado en reunión
// [v0.2] Simplificación proveedores (Sale con monto 0), entregas en notes
// [v0.3] Análisis de Excel reales: doble moneda, CashMovement unificado,
//        vendedores, turno de firmas, categorías de gasto ampliadas
// [v0.4] ExchangeRate diario (API), CashMovement→Installment link directo,
//        turno de firmas escalonado (DB + frontend calendar)
// [v0.5] Consolidado: DevelopmentType simplificado, originalAmount, permutas
// [v0.6] Trazabilidad de usuario: createdById en Sale, ExtraCharge, Person,
//        SigningSlot. SuperAdmin puede ver quién cargó cada operación.
// [v0.7] Multi-lote: groupId en Sale para agrupar ventas de múltiples lotes
//        bajo un mismo plan de pago (ej: SUMMER MARCELO lotes 212,213,214).
//
// ============================================================================
// FLUJOS CLAVE:
//
// ── VENTA NORMAL ──
// 1. Crear Person (CLIENTE)
// 2. Crear Sale → totalPrice, totalInstallments, regularInstallmentAmount
// 3. Auto-generar N Installments (restando refuerzos pactados del total)
// 4. Lot.status → VENDIDO
//
// ── PAGO DE CUOTA ──
// 1. Cobranza selecciona Installment pendiente
// 2. Sistema obtiene ExchangeRate del día
// 3. Crea CashMovement con installmentId + exchangeRateId
// 4. Installment.status → PAGADA
// 5. Movimiento aparece automáticamente en panel de Caja
//
// ── REFUERZO A MITAD DE PLAN ──
// 1. Se crea ExtraCharge nueva
// 2. Cuando se paga → CashMovement con extraChargeId
// 3. Se recalculan Installments pendientes:
//    nuevoMonto = saldoRestante / cuotasPendientes
// 4. originalAmount guarda el monto previo al recálculo
//
// ── PROVEEDOR PAGADO CON LOTE ──
// 1. Person con type = PROVEEDOR
// 2. Sale → totalPrice = 0, status = CESION
// 3. Lot → status = PERMUTA
// 4. Caja NO se toca. Detalle del servicio → Sale.notes
//
// ── ENTREGA DE PROPIEDAD COMO PARTE DE PAGO ──
// 1. Valor de la entrega se resta del totalPrice ANTES de calcular cuotas
// 2. Descripción de la propiedad → Sale.notes
//    Ej: "Entrega casa Bv. Oroño 1234, valuada USD 80.000"
// 3. totalPrice = precio lote - valor entrega
//
// ── CONTADO ──
// 1. Sale → totalPrice = monto, totalInstallments = 0, status = CONTADO
// 2. CashMovement tipo ENTREGA con el monto total
// 3. Lot → status = CONTADO
//
// ============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// GESTIÓN DE USUARIOS Y ROLES
// ============================================================================
// Roles y visibilidad por campo:
// - COBRANZA: nombre, email, teléfono, fecha cobro
// - FINANZAS: cuotas, montos, estados de pago
// - ADMINISTRACION: todo excepto caja
// - SUPER_ADMIN: acceso total
// Implementado en middleware de aplicación, no en DB.

enum Role {
  SUPER_ADMIN
  ADMINISTRACION
  FINANZAS
  COBRANZA
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  lastName  String   @map("last_name")
  role      Role     @default(COBRANZA)
  isActive  Boolean  @default(true) @map("is_active")
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Seller fields (merged from Seller model)
  isSeller       Boolean  @default(false) @map("is_seller")
  commissionRate Decimal? @db.Decimal(5, 2) @map("commission_rate")

  sentMessages     Message[]          @relation("SentMessages")
  receivedMessages MessageRecipient[]
  cashMovements    CashMovement[]     @relation("RegisteredBy")
  receipts         PaymentReceipt[]   @relation("GeneratedBy")
  auditLogs        AuditLog[]
  createdSales     Sale[]             @relation("SaleCreatedBy")
  createdCharges   ExtraCharge[]      @relation("ChargeCreatedBy")
  createdPersons   Person[]           @relation("PersonCreatedBy")
  createdSignings  SigningSlot[]      @relation("SigningCreatedBy")
  sellerSales      Sale[]             @relation("SaleSeller")
  sellerSignings   SigningSlot[]      @relation("SigningSeller")
  notifications    Notification[]

  @@map("users")
}

model RolePermission {
  id         String   @id @default(cuid())
  role       Role
  permission String
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([role, permission])
  @@map("role_permissions")
}

// ============================================================================
// COTIZACIÓN DIARIA USD/ARS
// ============================================================================
// Se obtiene de API gratuita (dolarapi.com o bluelytics.com.ar).
// Se guarda una vez por día. Al registrar cualquier transacción se stampa
// el exchangeRateId para trazabilidad histórica.
//
// API sugeridas (gratis, sin key):
// - https://dolarapi.com/v1/dolares
// - https://api.bluelytics.com.ar/v2/latest

model ExchangeRate {
  id           String   @id @default(cuid())
  date         DateTime @unique // Una entrada por día
  source       String   @default("dolarapi")

  officialBuy  Decimal? @db.Decimal(10, 2) @map("official_buy")
  officialSell Decimal? @db.Decimal(10, 2) @map("official_sell")
  blueBuy      Decimal? @db.Decimal(10, 2) @map("blue_buy")
  blueSell     Decimal? @db.Decimal(10, 2) @map("blue_sell")
  cryptoBuy    Decimal? @db.Decimal(10, 2) @map("crypto_buy")
  cryptoSell   Decimal? @db.Decimal(10, 2) @map("crypto_sell")

  createdAt    DateTime @default(now()) @map("created_at")

  cashMovements CashMovement[]

  @@index([date])
  @@map("exchange_rates")
}

// ============================================================================
// DESARROLLOS
// ============================================================================
// Fiderza (holding/oficina) = Development tipo INMOBILIARIO sin lotes.
// Solo se usa como centro de costos para imputar gastos con developmentId.
//
// "Proveedores" NO es un tipo de desarrollo. Es un filtro en el frontend:
// mostrar Sales donde person.type IN (PROVEEDOR, AMBOS).

enum DevelopmentStatus {
  PLANIFICACION
  EN_CURSO
  FINALIZADO
  PAUSADO
}

enum DevelopmentType {
  INMOBILIARIO  // Raíces de Alvear, Potus de Avellaneda, Fiderza (sin lotes)
  OTROS         // Items varios: casas en venta, vehículos, animales
}

model Development {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  description String?
  location    String?
  type        DevelopmentType   @default(INMOBILIARIO)
  status      DevelopmentStatus @default(EN_CURSO)
  imageUrl      String?           @map("image_url")
  googleMapsUrl String?           @map("google_maps_url")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  lots          Lot[]
  cashMovements CashMovement[]
  cashBalances  CashBalance[]
  signingSlots  SigningSlot[]

  @@map("developments")
}

// ============================================================================
// LOTES
// ============================================================================

enum LotStatus {
  DISPONIBLE
  RESERVADO
  VENDIDO
  CONTADO       // Pagado al contado
  ESCRITURADO
  CESION        // Transferido/cedido
  PERMUTA       // Entregado a proveedor como pago en especie
}

model Lot {
  id            String    @id @default(cuid())
  developmentId String    @map("development_id")
  lotNumber     String    @map("lot_number")
  block         String?
  area          Decimal?  @db.Decimal(10, 2)
  listPrice     Decimal?  @db.Decimal(12, 2) @map("list_price")
  status        LotStatus @default(DISPONIBLE)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  development Development @relation(fields: [developmentId], references: [id])
  tags        LotTag[]
  sale        Sale?

  @@unique([developmentId, lotNumber])
  @@index([status])
  @@index([developmentId, status])
  @@map("lots")
}

// ============================================================================
// TAGS (Etiquetas personalizables para lotes)
// ============================================================================
// Libres, definidas por el usuario. Ej: "lote comercial", "paga a fin de mes".
// Frontend con autocomplete para evitar duplicados.

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique // Slug interno: "lote-comercial"
  label     String           // Display: "Lote Comercial"
  color     String?          // Hex: "#FF5733"
  createdAt DateTime @default(now()) @map("created_at")

  lots LotTag[]

  @@map("tags")
}

model LotTag {
  id    String @id @default(cuid())
  lotId String @map("lot_id")
  tagId String @map("tag_id")

  lot Lot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([lotId, tagId])
  @@map("lot_tags")
}

// ============================================================================
// PERSONAS (CLIENTES / PROVEEDORES)
// ============================================================================
// Sidebar "Proveedores" = filtro: Sales WHERE person.type IN (PROVEEDOR, AMBOS)

enum PersonType {
  CLIENTE
  PROVEEDOR
  AMBOS
}

model Person {
  id        String     @id @default(cuid())
  type      PersonType @default(CLIENTE)
  firstName String     @map("first_name")
  lastName  String     @map("last_name")
  dni       String?    @unique
  cuit      String?    @unique
  email     String?
  phone     String?
  phone2    String?
  address   String?
  city      String?
  province  String?
  notes     String?    @db.Text
  isActive   Boolean    @default(true) @map("is_active")
  createdById String?   @map("created_by_id")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  sales         Sale[]
  cashMovements CashMovement[] @relation("PersonMovements")
  receipts      PaymentReceipt[]
  createdBy     User?          @relation("PersonCreatedBy", fields: [createdById], references: [id])

  @@index([type])
  @@index([isActive])
  @@map("persons")
}

// ============================================================================
// VENTAS
// ============================================================================

enum SaleStatus {
  ACTIVA
  CANCELADA
  COMPLETADA
  CONTADO     // Pagado al contado, sin plan de cuotas
  CESION      // Cedido/transferido (también para permutas a proveedores)
}

enum Currency {
  USD
  ARS
}

model Sale {
  id                       String     @id @default(cuid())
  groupId                  String?    @map("group_id") // Multi-lote: ventas con mismo groupId comparten plan de pago
  lotId                    String     @unique @map("lot_id")
  personId                 String     @map("person_id")
  sellerId                 String?    @map("seller_id")
  saleDate                 DateTime   @map("sale_date")
  signingDate              DateTime?  @map("signing_date")
  totalPrice               Decimal    @db.Decimal(12, 2) @map("total_price")
  downPayment              Decimal?   @db.Decimal(12, 2) @map("down_payment")
  currency                 Currency   @default(USD)
  totalInstallments        Int        @map("total_installments") // 0 = contado
  firstInstallmentAmount   Decimal?   @db.Decimal(12, 2) @map("first_installment_amount")
  regularInstallmentAmount Decimal?   @db.Decimal(12, 2) @map("regular_installment_amount")
  firstInstallmentMonth    String?    @map("first_installment_month")
  collectionDay            Int?       @map("collection_day")
  commissionAmount         Decimal?   @db.Decimal(12, 2) @map("commission_amount")
  exchangeRateOverride     Decimal?   @db.Decimal(10, 2) @map("exchange_rate_override")
  status                   SaleStatus @default(ACTIVA)
  notes                    String?    @db.Text // Entregas de propiedad, permutas, etc.
  paymentWindow            String?    @map("payment_window") // Ventana de pago: "del 1 al 20", "vence el 30", etc.
  createdById              String     @map("created_by_id")
  createdAt                DateTime   @default(now()) @map("created_at")
  updatedAt                DateTime   @updatedAt @map("updated_at")

  lot           Lot              @relation(fields: [lotId], references: [id])
  person        Person           @relation(fields: [personId], references: [id])
  seller        User?            @relation("SaleSeller", fields: [sellerId], references: [id])
  createdBy     User             @relation("SaleCreatedBy", fields: [createdById], references: [id])
  installments  Installment[]
  extraCharges  ExtraCharge[]
  cashMovements CashMovement[]
  receipts      PaymentReceipt[]
  signingSlots  SigningSlot[]

  @@index([groupId])
  @@index([status])
  @@index([personId])
  @@index([sellerId])
  @@map("sales")
}

// ============================================================================
// CUOTAS ORDINARIAS
// ============================================================================
// originalAmount: se llena cuando un recálculo por refuerzo modifica el monto.
// Queda null si la cuota nunca fue recalculada.

enum InstallmentStatus {
  PENDIENTE
  PAGADA
  VENCIDA
  PARCIAL
}

model Installment {
  id                String            @id @default(cuid())
  saleId            String            @map("sale_id")
  installmentNumber Int               @map("installment_number")
  amount            Decimal           @db.Decimal(12, 2) // Monto actual
  originalAmount    Decimal?          @db.Decimal(12, 2) @map("original_amount") // Pre-recálculo
  currency          Currency          @default(USD)
  dueDate           DateTime          @map("due_date")
  monthLabel        String?           @map("month_label") // "ABRIL 2025"
  status            InstallmentStatus @default(PENDIENTE)

  paidAmount     Decimal   @default(0) @db.Decimal(12, 2) @map("paid_amount")
  paidInCurrency Currency? @map("paid_in_currency") // Moneda real del pago
  paidDate       DateTime? @map("paid_date")

  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sale          Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  cashMovements CashMovement[]

  @@unique([saleId, installmentNumber])
  @@index([status])
  @@index([dueDate])
  @@map("installments")
}

// ============================================================================
// CUOTAS DE REFUERZO / EXTRAORDINARIAS
// ============================================================================
// Pueden crearse al inicio de la venta o a mitad de plan.
// Al pagarse un refuerzo a mitad de plan → recálculo de cuotas pendientes.

enum ExtraChargeStatus {
  PENDIENTE
  PAGADA
  VENCIDA
  PARCIAL
}

model ExtraCharge {
  id          String            @id @default(cuid())
  saleId      String            @map("sale_id")
  description String
  amount      Decimal           @db.Decimal(12, 2)
  currency    Currency          @default(USD)
  dueDate     DateTime          @map("due_date")
  status      ExtraChargeStatus @default(PENDIENTE)
  paidAmount  Decimal           @default(0) @db.Decimal(12, 2) @map("paid_amount")
  paidDate    DateTime?         @map("paid_date")
  isInKind    Boolean           @default(false) @map("is_in_kind")
  inKindType  String?           @map("in_kind_type")
  notified    Boolean           @default(false) // Alerta 3 días antes enviada
  notes       String?
  createdById String            @map("created_by_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  sale          Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdBy     User           @relation("ChargeCreatedBy", fields: [createdById], references: [id])
  cashMovements CashMovement[]

  @@index([saleId])
  @@index([dueDate])
  @@map("extra_charges")
}

// ============================================================================
// CAJA - MOVIMIENTOS UNIFICADOS
// ============================================================================

enum MovementType {
  CUOTA           // Pago de cuota
  ENTREGA         // Pago inicial / entrega de lote / contado
  COMISION        // Comisión a vendedor
  SUELDO          // Sueldo de empleados y socios
  CAMBIO          // Conversión USD ↔ ARS
  RETIRO          // Retiro de socios
  GASTO_PROYECTO  // Gastos del desarrollo (corta pasto, renders, agrimensor)
  GASTO_OFICINA   // Alquiler, insumos, electricista, etc.
  FIDEICOMISO     // Pagos de fideicomiso
  BANCO           // Movimientos bancarios, extracciones
  CONTABLE        // Honorarios contador, estudio contable
  PRESTAMO        // Cuotas de préstamo
  IMPUESTO        // IIBB, sellos, API, certificaciones
  ALQUILER        // Alquileres cobrados/pagados
  MARKETING       // Gastos de marketing y publicidad
  COCHERA         // Cocheras (ingresos por alquiler/venta)
  DESARROLLO      // Gastos generales de desarrollo inmobiliario
  VARIOS          // Otros (taxis, limpieza, kiosco, etc.)
}

model CashMovement {
  id             String       @id @default(cuid())
  developmentId  String?      @map("development_id")
  personId       String?      @map("person_id")
  saleId         String?      @map("sale_id")
  installmentId  String?      @map("installment_id")
  extraChargeId  String?      @map("extra_charge_id")
  exchangeRateId String?      @map("exchange_rate_id")

  date           DateTime
  type           MovementType
  concept        String       // "CUOTA 5 LOTE 194", "SUELDO MARCOS"
  detail         String?      @db.Text

  arsIncome      Decimal?     @db.Decimal(14, 2) @map("ars_income")
  arsExpense     Decimal?     @db.Decimal(14, 2) @map("ars_expense")
  usdIncome      Decimal?     @db.Decimal(12, 2) @map("usd_income")
  usdExpense     Decimal?     @db.Decimal(12, 2) @map("usd_expense")
  manualRate     Decimal?     @db.Decimal(10, 2) @map("manual_rate")

  receiptNumber  String?      @map("receipt_number")
  registeredById String       @map("registered_by_id")
  notes          String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  development  Development?  @relation(fields: [developmentId], references: [id])
  person       Person?       @relation("PersonMovements", fields: [personId], references: [id])
  sale         Sale?         @relation(fields: [saleId], references: [id])
  installment  Installment?  @relation(fields: [installmentId], references: [id])
  extraCharge  ExtraCharge?  @relation(fields: [extraChargeId], references: [id])
  exchangeRate ExchangeRate? @relation(fields: [exchangeRateId], references: [id])
  registeredBy User          @relation("RegisteredBy", fields: [registeredById], references: [id])
  receipt      PaymentReceipt?

  @@index([date])
  @@index([type])
  @@index([developmentId])
  @@index([saleId])
  @@index([personId])
  @@index([installmentId])
  @@map("cash_movements")
}

// ============================================================================
// SALDOS DE CAJA (Snapshots mensuales)
// ============================================================================

model CashBalance {
  id            String    @id @default(cuid())
  developmentId String?   @map("development_id")
  month         Int
  year          Int
  arsBalance    Decimal   @db.Decimal(14, 2) @map("ars_balance")
  usdBalance    Decimal   @db.Decimal(12, 2) @map("usd_balance")
  closedAt      DateTime? @map("closed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  development Development? @relation(fields: [developmentId], references: [id])

  @@unique([developmentId, month, year])
  @@map("cash_balances")
}

// ============================================================================
// RECIBOS DE PAGO
// ============================================================================
// Documento no-legal auto-generado:
// "Recibí de [nombre], $[monto] en concepto de cuota [N]
//  correspondiente al lote [lote], fecha [fecha]."
// Envío por email. WhatsApp vía deep link (opcional).
// Membrete configurable en SystemConfig.

model PaymentReceipt {
  id             String    @id @default(cuid())
  cashMovementId String    @unique @map("cash_movement_id")
  saleId         String    @map("sale_id")
  personId       String    @map("person_id")
  receiptNumber  String    @map("receipt_number")
  content        String    @db.Text
  sentByEmail    Boolean   @default(false) @map("sent_by_email")
  sentAt         DateTime? @map("sent_at")
  generatedById  String    @map("generated_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")

  cashMovement CashMovement @relation(fields: [cashMovementId], references: [id])
  sale         Sale         @relation(fields: [saleId], references: [id])
  person       Person       @relation(fields: [personId], references: [id])
  generatedBy  User         @relation("GeneratedBy", fields: [generatedById], references: [id])

  @@map("payment_receipts")
}

// ============================================================================
// TURNO DE FIRMAS (Agenda de escrituración)
// ============================================================================
// Fase 1 (MVP): SigningSlot en DB + react-big-calendar en frontend.
//   Vista semanal, horarios en filas, días en columnas.
// Fase 2 (futuro): Agregar googleEventId para sync con Google Calendar.
//   No requiere cambios en el modelo de datos.

enum SigningStatus {
  PENDIENTE
  CONFIRMADA
  COMPLETADA
  CANCELADA
  REPROGRAMADA
}

model SigningSlot {
  id            String        @id @default(cuid())
  developmentId String?       @map("development_id")
  sellerId      String?       @map("seller_id")
  date          DateTime
  time          String        // "09:00", "09:30"
  endTime       String?       @map("end_time")
  lotInfo       String        @map("lot_info")
  clientName    String?       @map("client_name")
  lotNumbers    String?       @map("lot_numbers")
  status        SigningStatus @default(PENDIENTE)
  notes         String?
  createdById   String?      @map("created_by_id")
  saleId        String?       @map("sale_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  development Development? @relation(fields: [developmentId], references: [id])
  seller      User?        @relation("SigningSeller", fields: [sellerId], references: [id])
  createdBy   User?        @relation("SigningCreatedBy", fields: [createdById], references: [id])
  sale        Sale?         @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([status])
  @@index([saleId])
  @@map("signing_slots")
}

// ============================================================================
// MENSAJES INTERNOS
// ============================================================================
// Sistema de alertas entre usuarios visible al login.
// Caso de uso: vendedor deja mensaje domingo 10pm,
// admin lo ve lunes al conectarse.
// Todos pueden enviarse mensajes entre sí.

model Message {
  id        String   @id @default(cuid())
  senderId  String   @map("sender_id")
  subject   String?
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  sender     User               @relation("SentMessages", fields: [senderId], references: [id])
  recipients MessageRecipient[]

  @@map("messages")
}

model MessageRecipient {
  id        String    @id @default(cuid())
  messageId String    @map("message_id")
  userId    String    @map("user_id")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("message_recipients")
}

// ============================================================================
// NOTIFICACIONES
// ============================================================================
// REFUERZO_PROXIMO: query al cargar página:
//   ExtraCharge WHERE dueDate BETWEEN NOW() AND NOW()+3d
//   AND status = PENDIENTE AND notified = false
// Con 6 usuarios no se justifica cron job.

enum NotificationType {
  REFUERZO_PROXIMO  // 3 días antes
  CUOTA_VENCIDA
  PAGO_RECIBIDO
  FIRMA_PROXIMA     // 1 día antes del turno
  SISTEMA
}

model Notification {
  id            String           @id @default(cuid())
  userId        String           @map("user_id")
  type          NotificationType
  title         String
  body          String
  referenceType String?          @map("reference_type") // "ExtraCharge", "Installment", etc.
  referenceId   String?          @map("reference_id")
  read          Boolean          @default(false)
  createdAt     DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

// ============================================================================
// AUDITORÍA
// ============================================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String   // "CREATE", "UPDATE", "DELETE"
  entity    String   // "Sale", "CashMovement", etc.
  entityId  String   @map("entity_id")
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// CONFIGURACIÓN DEL SISTEMA
// ============================================================================
// Pares clave-valor. Ejemplos:
// - "company_name" → "Raíces de Alvear"
// - "receipt_header" → "Recibí de..."
// - "receipt_footer" → "Firma y aclaración"
// - "company_logo_url" → "/uploads/logo.png"
// - "company_cuit" → "30-12345678-9"
// - "default_exchange_source" → "blue_sell"

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text

  @@map("system_config")
}

# =============================================================================
# Sistema Inmobiliaria - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# --- Database ---
DATABASE_URL="postgresql://user:password@localhost:5432/sistema_inmobiliaria"

# --- Auth.js (NextAuth) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-secure-random-string-here"
# Base URL of the app (no trailing slash)
AUTH_URL="http://localhost:3000"

# --- Cron Jobs ---
# Secret token for authenticating cron job requests (Bearer token)
# Generate with: openssl rand -hex 32
CRON_SECRET="generate-a-secure-random-string-here"

# --- Seed (optional) ---
# Override the default admin password used by prisma db seed
# SEED_ADMIN_PASSWORD="your-strong-password-here"

# --- Email (Nodemailer SMTP) ---
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Sistema Inmobiliaria <noreply@inmobiliaria.com>"
